@page
@model LangGrader.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<h1 class="page-title">Login</h1>
<p class="page-subtitle">Sign in with your student number or administrator ID.</p>

<div class="card">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="message message-error">
            @Model.ErrorMessage
        </div>
    }

    <form method="post" class="form-grid">
        <input type="hidden" asp-for="ReturnUrl" />

        <div class="form-row">
            <label asp-for="Input.StudentNo">Student Number or Admin ID</label>
            <input asp-for="Input.StudentNo" autocomplete="username" />
        </div>

        <div class="form-row">
            <label asp-for="Input.Password">Password</label>
            <input asp-for="Input.Password" type="password" autocomplete="current-password" />
        </div>

        <div class="toolbar">
            <button type="submit" class="button-primary">Login</button>
        </div>
    </form>
</div>
