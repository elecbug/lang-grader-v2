@page
@model LangGrader.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<h1>Login</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div style="color: red; margin-bottom: 1rem;">
        @Model.ErrorMessage
    </div>
}

<form method="post">
    <input type="hidden" asp-for="ReturnUrl" />

    <div>
        <label asp-for="Input.StudentNo">Student Number or Admin ID</label><br />
        <input asp-for="Input.StudentNo" />
    </div>

    <div style="margin-top: 0.75rem;">
        <label asp-for="Input.Password">Password</label><br />
        <input asp-for="Input.Password" type="password" />
    </div>

    <div style="margin-top: 1rem;">
        <button type="submit">Login</button>
    </div>
</form>