@page
@model LangGrader.Pages.Assignments.IndexModel
@{
    ViewData["Title"] = "Assignments";
}

<h1>Assignments</h1>

<p>
    Signed in as:
    @User.FindFirst("StudentName")?.Value
    (@User.FindFirst("StudentNo")?.Value)
</p>

<p>
    <a asp-page="/Logout">Logout</a>
</p>

@if (Model.Assignments.Count == 0)
{
    <p>No assignments are currently available.</p>
}
else
{
    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr>
                <th>Assignment</th>
                <th>Status</th>
                <th>Deadline</th>
                <th>Submission</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var assignment in Model.Assignments)
            {
                <tr>
                    <td>@assignment.Title</td>
                    <td>
                        @if (assignment.IsFrozen)
                        {
                            <span>Frozen</span>
                        }
                        else if (DateTime.UtcNow > assignment.DeadlineAt)
                        {
                            <span>Closed</span>
                        }
                        else
                        {
                            <span>Open</span>
                        }
                    </td>
                    <td>@TimeViewHelper.FormatKstMinute(assignment.DeadlineAt)</td>
                    <td>
                        <a asp-page="/Assignments/Submit" asp-route-id="@assignment.Id">
                            Submit / Update
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}