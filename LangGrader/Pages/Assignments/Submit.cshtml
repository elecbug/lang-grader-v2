@page "{id:long}"
@model LangGrader.Pages.Assignments.SubmitModel
@{
    ViewData["Title"] = "Submit Assignment";
}

<h1 class="page-title">@Model.AssignmentTitle</h1>

@if (!string.IsNullOrWhiteSpace(Model.AssignmentDescription))
{
    <div class="card">
        <h2 class="card-title">Assignment Description</h2>
        <div class="assignment-description">
            @Model.AssignmentDescription
        </div>
    </div>
}

<p class="page-subtitle">Deadline: <strong>@Model.DeadlineText</strong></p>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="message message-success">
        @Model.Message
    </div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="message message-error">
        @Model.ErrorMessage
    </div>
}

<div class="card">
    <h2 class="card-title">Submit GitHub URLs</h2>

    <form method="post" class="form-grid submit-form">
        <div id="url-list">
            @for (var i = 0; i < Model.Input.Items.Count; i++)
            {
                <div class="url-row">
                    <div class="form-row">
                        <label>GitHub URL</label>
                        <input name="Input.Items[@i].Url"
                               value="@Model.Input.Items[i].Url"
                               placeholder="https://github.com/owner/repo or https://github.com/owner/repo/tree/main/folder" />
                        <div class="field-help">Repository, folder, file, and raw GitHub URLs are supported.</div>
                    </div>

                    <div class="form-row">
                        <label>Main file path</label>
                        <input name="Input.Items[@i].MainFilePath"
                               value="@Model.Input.Items[i].MainFilePath"
                               placeholder="main.c" />
                    </div>
                </div>
            }
        </div>

        <div class="toolbar">
            <button type="button" class="button-secondary" onclick="addUrlRow()">Add URL</button>
            <button type="submit" class="button-primary">Submit</button>
            <a class="button button-secondary" asp-page="/Assignments/Index">Back to Assignments</a>
        </div>
    </form>
</div>

@if (Model.PreviousSubmissions.Count > 0)
{
    <h2 class="section-title">Previous Submissions</h2>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Submitted At</th>
                    <th>Status</th>
                    <th>Items</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var submission in Model.PreviousSubmissions)
                {
                    <tr>
                        <td class="nowrap">@TimeViewHelper.FormatKst(submission.SubmittedAt)</td>
                        <td>
                            @if (submission.Status == "Valid")
                            {
                                <span class="badge badge-success">@submission.Status</span>
                            }
                            else if (submission.Status == "Deleted")
                            {
                                <span class="badge badge-muted">@submission.Status</span>
                            }
                            else if (submission.Status == "ValidationFailed")
                            {
                                <span class="badge badge-error">@submission.Status</span>
                            }
                            else
                            {
                                <span class="badge badge-info">@submission.Status</span>
                            }
                        </td>
                        <td>
                            @foreach (var item in submission.Items)
                            {
                                <div class="item-block">
                                    <div class="info-block">
                                        <div class="break-all">
                                            <strong>URL:</strong> @item.OriginalUrl
                                        </div>

                                        <div>
                                            <strong>Kind:</strong> @item.UrlKind
                                        </div>

                                        <div>
                                            <strong>Owner:</strong> @item.Owner
                                        </div>

                                        <div>
                                            <strong>Repo:</strong> @item.Repo
                                        </div>

                                        <div>
                                            <strong>Branch:</strong> @(string.IsNullOrWhiteSpace(item.Branch) ? "(default)" : item.Branch)
                                        </div>

                                        <div class="break-all">
                                            <strong>Path:</strong> @(string.IsNullOrWhiteSpace(item.Path) ? "/" : item.Path)
                                        </div>

                                        <div>
                                            <strong>Main File:</strong> @item.MainFilePath
                                        </div>

                                        <div>
                                            <strong>Status:</strong>
                                            <span class="@GetStatusBadgeClass(item.Status)">
                                                @item.Status
                                            </span>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(item.ObservedSha))
                                        {
                                            <div class="break-all">
                                                <strong>Observed SHA:</strong> @item.ObservedSha
                                            </div>
                                        }

                                        @if (item.ValidatedAt.HasValue)
                                        {
                                            <div>
                                                <strong>Validated At:</strong>
                                                <span class="nowrap">@TimeViewHelper.FormatKst(item.ValidatedAt.Value)</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </td>
                        <td>
                            @if (!Model.IsAssignmentFrozen)
                            {
                                <form method="post"
                                      class="inline-form"
                                      asp-page-handler="Delete"
                                      asp-route-id="@Model.AssignmentId"
                                      asp-route-submissionId="@submission.Id"
                                      onsubmit="return confirm('Delete this submission?');">
                                    <button type="submit" class="button-danger button-small">Delete</button>
                                </form>
                            }
                            else
                            {
                                <span class="badge badge-muted">Locked</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        function addUrlRow() {
            const list = document.getElementById("url-list");
            const index = list.querySelectorAll(".url-row").length;

            const div = document.createElement("div");
            div.className = "url-row";

            div.innerHTML = `
                <div class="form-row">
                    <label>GitHub URL</label>
                    <input name="Input.Items[${index}].Url"
                           placeholder="https://github.com/owner/repo or https://github.com/owner/repo/tree/main/folder" />
                    <div class="field-help">Repository, folder, file, and raw GitHub URLs are supported.</div>
                </div>

                <div class="form-row">
                    <label>Main file path</label>
                    <input name="Input.Items[${index}].MainFilePath"
                           placeholder="main.c" />
                </div>
            `;

            list.appendChild(div);
        }
    </script>
}

@functions {
    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Valid" => "badge badge-success",
            "ValidationFailed" => "badge badge-error",
            "Validating" => "badge badge-warning",
            "PendingValidation" => "badge badge-warning",
            "Deleted" => "badge badge-muted",
            "InvalidUrl" => "badge badge-error",
            "CloneFailed" => "badge badge-error",
            "CloneTimeout" => "badge badge-error",
            "DefaultBranchNotFound" => "badge badge-error",
            "PathNotFound" => "badge badge-error",
            "MainFileNotFound" => "badge badge-error",
            "FileNotFound" => "badge badge-error",
            "RequiredFileMissing" => "badge badge-error",
            "RequiredFileConfigInvalid" => "badge badge-error",
            "UnsupportedUrlKind" => "badge badge-error",
            "SystemError" => "badge badge-error",
            _ => "badge badge-muted"
        };
    }
}