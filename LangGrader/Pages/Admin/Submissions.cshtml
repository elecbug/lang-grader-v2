@page
@model LangGrader.Pages.Admin.SubmissionsModel
@{
    ViewData["Title"] = "Submission Summary";
}

<h1 class="page-title">Submission Summary</h1>
<p class="page-subtitle">
    This page shows the effective submission candidate for each student. Deleted submissions are excluded from effective selection but counted for audit purposes.
</p>

<div class="toolbar">
    <a class="button button-secondary" asp-page="/Admin/Database">Database Viewer</a>
    <a class="button button-secondary" asp-page="/Assignments/Index">Back to Assignments</a>
</div>

@if (Model.Assignments.Count == 0)
{
    <div class="empty-state">No assignments found.</div>
}
else
{
    <div class="card">
        <form method="get" class="form-grid">
            <div class="form-row">
                <label for="assignmentId">Assignment</label>
                <select id="assignmentId" name="assignmentId">
                    @foreach (var assignment in Model.Assignments)
                    {
                        if (assignment.Id == Model.AssignmentId)
                        {
                            <option value="@assignment.Id" selected>@assignment.Title</option>
                        }
                        else
                        {
                            <option value="@assignment.Id">@assignment.Title</option>
                        }
                    }
                </select>
            </div>

            <div class="toolbar">
                <button type="submit" class="button-primary">Load</button>
            </div>
        </form>
    </div>
}

@if (Model.Summary is not null)
{
    <div class="card">
        <div class="toolbar toolbar-spread">
            <div>
                <h2 class="card-title">@Model.Summary.Assignment.Title</h2>
                <div class="text-muted">
                    <strong>Deadline:</strong> @TimeViewHelper.FormatKst(Model.Summary.Assignment.DeadlineAt)
                </div>
            </div>

            <div>
                @if (!Model.Summary.Assignment.IsFrozen)
                {
                    <form method="post"
                          class="inline-form"
                          asp-page-handler="Freeze"
                          asp-route-assignmentId="@Model.Summary.Assignment.Id"
                          onsubmit="return confirm('Freeze this assignment? This will lock the current effective submissions.');">
                        <button type="submit" class="button-warning">Freeze Assignment</button>
                    </form>
                }
                else
                {
                    <form method="post"
                          class="inline-form"
                          asp-page-handler="Unfreeze"
                          asp-route-assignmentId="@Model.Summary.Assignment.Id"
                          onsubmit="return confirm('Unfreeze this assignment? This will clear freeze metadata and delete frozen snapshots.');">
                        <button type="submit" class="button-danger">Unfreeze Assignment</button>
                    </form>
                }
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Message))
        {
            <div class="message message-success">@Model.Message</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="message message-error">@Model.ErrorMessage</div>
        }

        @if (Model.Summary.Assignment.IsFrozen)
        {
            <div class="message message-info">This assignment is frozen.</div>
        }

        <div class="info-block">
            <div>
                <strong>Total Students:</strong>
                <span>@Model.Summary.TotalStudents</span>
            </div>
            <div>
                <strong>Submitted:</strong>
                <span>@Model.Summary.SubmittedStudents</span>
            </div>
            <div>
                <strong>Ready for Freeze:</strong>
                <span>@Model.Summary.ReadyStudents</span>
            </div>
            <div>
                <strong>Missing:</strong>
                <span>@Model.Summary.MissingStudents</span>
            </div>
            <div>
                <strong>Frozen:</strong>
                @if (Model.Summary.Assignment.IsFrozen)
                {
                    <span class="badge badge-info">Frozen</span>
                }
                else
                {
                    <span class="badge badge-muted">Not Frozen</span>
                }
            </div>

            <div>
                <strong>Frozen At:</strong>
                @if (Model.Summary.Assignment.FrozenAt.HasValue)
                {
                    @TimeViewHelper.FormatKst(Model.Summary.Assignment.FrozenAt.Value)
                }
                else
                {
                    <span>-</span>
                }
            </div>

            <div class="break-all">
                <strong>Freeze Root:</strong> @(Model.Summary.Assignment.FreezeRootPath ?? "-")
            </div>
        </div>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Student No</th>
                    <th>Name</th>
                    <th>Total</th>
                    <th>Deleted</th>
                    <th>Latest Submission</th>
                    <th>Effective Submission</th>
                    <th>Effective Status</th>
                    <th>Flags</th>
                    <th>Reason</th>
                    <th>Freeze</th>
                    <th>Items</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.Summary.Rows)
                {
                    <tr>
                        <td class="nowrap"><strong>@row.StudentNo</strong></td>
                        <td>@row.StudentName</td>
                        <td>@row.TotalSubmissionCount</td>
                        <td>@row.DeletedSubmissionCount</td>

                        <td>
                            @if (row.LatestSubmission is null)
                            {
                                <span class="text-muted">-</span>
                            }
                            else
                            {
                                <div class="info-block">
                                    <div><strong>Id:</strong> @row.LatestSubmission.Id</div>
                                    <div><strong>Time:</strong> <span class="nowrap">@TimeViewHelper.FormatKst(row.LatestSubmission.SubmittedAt)</span></div>
                                    <div>
                                        <strong>Status:</strong>
                                        <span class="@GetStatusBadgeClass(row.LatestSubmission.Status)">
                                            @row.LatestSubmission.Status
                                        </span>
                                    </div>
                                    <div><strong>Deleted:</strong> @row.LatestSubmission.IsDeleted</div>
                                </div>
                            }
                        </td>

                        <td>
                            @if (row.EffectiveSubmission is null)
                            {
                                <span class="text-muted">-</span>
                            }
                            else
                            {
                                <div class="info-block">
                                    <div><strong>Id:</strong> @row.EffectiveSubmission.Id</div>
                                    <div><strong>Time:</strong> <span class="nowrap">@TimeViewHelper.FormatKst(row.EffectiveSubmission.SubmittedAt)</span></div>
                                    <div>
                                        <strong>Status:</strong>
                                        <span class="@GetStatusBadgeClass(row.EffectiveSubmission.Status)">
                                            @row.EffectiveSubmission.Status
                                        </span>
                                    </div>
                                    <div><strong>Late:</strong> @row.EffectiveSubmission.IsLate</div>

                                    @if (!Model.Summary.Assignment.IsFrozen && !row.EffectiveSubmission.IsDeleted)
                                    {
                                        <div>
                                            <form method="post"
                                                  class="inline-form"
                                                  asp-page-handler="RevalidateSubmission"
                                                  asp-route-assignmentId="@Model.Summary.Assignment.Id"
                                                  asp-route-submissionId="@row.EffectiveSubmission.Id"
                                                  onsubmit="return confirm('Revalidate this submission?');">
                                                <button type="submit" class="button-secondary button-small">
                                                    Revalidate Submission
                                                </button>
                                            </form>
                                        </div>
                                    }
                                </div>
                            }
                        </td>

                        <td>
                            @if (row.IsReadyForFreeze)
                            {
                                <span class="badge badge-success">@row.EffectiveStatus</span>
                            }
                            else if (row.EffectiveStatus == "Missing")
                            {
                                <span class="badge badge-muted">@row.EffectiveStatus</span>
                            }
                            else if (row.EffectiveStatus == "Late Only")
                            {
                                <span class="badge badge-warning">@row.EffectiveStatus</span>
                            }
                            else
                            {
                                <span class="badge badge-error">@row.EffectiveStatus</span>
                            }
                        </td>

                        <td>
                            @if (row.HasLateSubmission)
                            {
                                <div><span class="badge badge-warning">Late exists</span></div>
                            }

                            @if (row.HasValidationFailure)
                            {
                                <div><span class="badge badge-error">Validation failed</span></div>
                            }

                            @if (!row.HasLateSubmission && !row.HasValidationFailure)
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>

                        <td>@row.Reason</td>

                        <td>
                            @if (row.EffectiveSubmission is null)
                            {
                                <span class="text-muted">-</span>
                            }
                            else
                            {
                                <div class="info-block">
                                    <div><strong>Selected:</strong> @row.EffectiveSubmission.IsSelectedForFreeze</div>
                                    <div>
                                        <strong>Status:</strong>
                                        <span class="@GetStatusBadgeClass(row.EffectiveSubmission.FreezeStatus)">
                                            @row.EffectiveSubmission.FreezeStatus
                                        </span>
                                    </div>

                                    @if (row.EffectiveSubmission.FrozenAt.HasValue)
                                    {
                                        <div><strong>Frozen At:</strong> <span class="nowrap">@TimeViewHelper.FormatKst(row.EffectiveSubmission.FrozenAt.Value)</span></div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(row.EffectiveSubmission.FreezeMessage))
                                    {
                                        <div class="break-all"><strong>Message:</strong> @row.EffectiveSubmission.FreezeMessage</div>
                                    }
                                </div>
                            }
                        </td>

                        <td>
                            @if (row.EffectiveSubmission is null || row.EffectiveSubmission.Items.Count == 0)
                            {
                                <span class="text-muted">-</span>
                            }
                            else
                            {
                                @foreach (var item in row.EffectiveSubmission.Items)
                                {
                                    <div class="item-block">
                                        <div class="info-block">
                                            <div><strong>Item Id:</strong> @item.Id</div>
                                            <div class="break-all"><strong>URL:</strong> @item.OriginalUrl</div>
                                            <div><strong>Kind:</strong> @item.UrlKind</div>
                                            <div><strong>Repo:</strong> @item.Owner / @item.Repo</div>
                                            <div><strong>Branch:</strong> @(string.IsNullOrWhiteSpace(item.Branch) ? "(default)" : item.Branch)</div>
                                            <div class="break-all"><strong>Path:</strong> @(string.IsNullOrWhiteSpace(item.Path) ? "/" : item.Path)</div>
                                            <div><strong>Main File:</strong> @item.MainFilePath</div>

                                            <div>
                                                <strong>Status:</strong>
                                                <span class="@GetStatusBadgeClass(item.Status)">
                                                    @item.Status
                                                </span>
                                            </div>

                                            <div class="break-all"><strong>Observed SHA:</strong> @(item.ObservedSha ?? "-")</div>

                                            @if (item.ValidatedAt.HasValue)
                                            {
                                                <div><strong>Validated At:</strong> <span class="nowrap">@TimeViewHelper.FormatKst(item.ValidatedAt.Value)</span></div>
                                            }

                                            @if (!Model.Summary.Assignment.IsFrozen)
                                            {
                                                <div>
                                                    <form method="post"
                                                          class="inline-form"
                                                          asp-page-handler="RevalidateItem"
                                                          asp-route-assignmentId="@Model.Summary.Assignment.Id"
                                                          asp-route-itemId="@item.Id"
                                                          onsubmit="return confirm('Revalidate this item?');">
                                                        <button type="submit" class="button-secondary button-small">
                                                            Revalidate Item
                                                        </button>
                                                    </form>
                                                </div>
                                            }

                                            <div class="break-all"><strong>Final SHA:</strong> @(item.FinalSha ?? "-")</div>
                                            <div class="break-all"><strong>Snapshot:</strong> @(item.SnapshotPath ?? "-")</div>

                                            @if (!string.IsNullOrWhiteSpace(item.SnapshotPath))
                                            {
                                                <div>
                                                    @if (Model.SnapshotFiles.TryGetValue(item.Id, out var snapshotInfo) && snapshotInfo.Exists)
                                                    {
                                                        <a class="button button-primary button-small"
                                                           asp-page-handler="DownloadSnapshot"
                                                           asp-route-itemId="@item.Id">
                                                            Download Snapshot
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-warning">Snapshot missing</span>

                                                        @if (snapshotInfo is not null && !string.IsNullOrWhiteSpace(snapshotInfo.ErrorMessage))
                                                        {
                                                            <div class="text-muted">
                                                                <strong>Snapshot Error:</strong> @snapshotInfo.ErrorMessage
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div>
                                                    <span class="badge badge-muted">No snapshot</span>
                                                </div>
                                            }

                                            @if (Model.SnapshotFiles.TryGetValue(item.Id, out var fileList) && fileList.Exists)
                                            {
                                                <details>
                                                    <summary>Snapshot files (@fileList.Entries.Count@(fileList.IsTruncated ? "+" : ""))</summary>

                                                    @if (fileList.Entries.Count == 0)
                                                    {
                                                        <div class="text-muted">No files found in snapshot.</div>
                                                    }
                                                    else
                                                    {
                                                        <ul class="compact-list">
                                                            @foreach (var entry in fileList.Entries)
                                                            {
                                                                <li><code>@entry</code></li>
                                                            }
                                                        </ul>

                                                        @if (fileList.IsTruncated)
                                                        {
                                                            <div class="text-muted">
                                                                File list was truncated.
                                                            </div>
                                                        }
                                                    }
                                                </details>
                                            }

                                            @if (item.FrozenAt.HasValue)
                                            {
                                                <div><strong>Item Frozen At:</strong> <span class="nowrap">@TimeViewHelper.FormatKst(item.FrozenAt.Value)</span></div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@functions {
    private static string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Valid" => "badge badge-success",
            "Ready" => "badge badge-success",
            "Frozen" => "badge badge-info",
            "Freezing" => "badge badge-warning",
            "NotFrozen" => "badge badge-muted",
            "NotSelected" => "badge badge-muted",
            "ValidationFailed" => "badge badge-error",
            "FreezeFailed" => "badge badge-error",
            "Validating" => "badge badge-warning",
            "PendingValidation" => "badge badge-warning",
            "Missing" => "badge badge-muted",
            "Deleted" => "badge badge-muted",
            "InvalidUrl" => "badge badge-error",
            "CloneFailed" => "badge badge-error",
            "CloneTimeout" => "badge badge-error",
            "DefaultBranchNotFound" => "badge badge-error",
            "PathNotFound" => "badge badge-error",
            "MainFileNotFound" => "badge badge-error",
            "FileNotFound" => "badge badge-error",
            "UnsupportedUrlKind" => "badge badge-error",
            "SystemError" => "badge badge-error",
            _ => "badge badge-muted"
        };
    }
}