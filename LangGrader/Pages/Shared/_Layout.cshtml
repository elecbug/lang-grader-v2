<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - LangGrader</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body>
    <header style="border-bottom: 1px solid #ccc; padding: 1rem; margin-bottom: 1rem;">
        <strong>LangGrader</strong>

        <nav style="margin-top: 0.5rem;">
            <a asp-page="/Index">Home</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <span> | </span>
                <a asp-page="/Assignments/Index">Assignments</a>
                <span> | </span>
                <a asp-page="/Logout">Logout</a>
            }
            else
            {
                <span> | </span>
                <a asp-page="/Login">Login</a>
            }
        </nav>
    </header>

    <main style="padding: 1rem;">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>