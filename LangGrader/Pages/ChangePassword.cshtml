@page
@model LangGrader.Pages.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<h1 class="page-title">Change Password</h1>

@if (Model.Required)
{
    <div class="message message-warning">
        You must change your initial password before continuing.
    </div>
}

<div class="card">
    <form method="post" class="form-grid">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="All" class="message message-error"></div>

        <div class="form-row">
            <label asp-for="Input.CurrentPassword">Current password</label>
            <input asp-for="Input.CurrentPassword" type="password" autocomplete="current-password" />
        </div>

        <div class="form-row">
            <label asp-for="Input.NewPassword">New password</label>
            <input asp-for="Input.NewPassword" type="password" autocomplete="new-password" />
            <div class="text-muted">
                Use at least 6 characters.
            </div>
        </div>

        <div class="form-row">
            <label asp-for="Input.ConfirmNewPassword">Confirm new password</label>
            <input asp-for="Input.ConfirmNewPassword" type="password" autocomplete="new-password" />
        </div>

        <div class="toolbar">
            <button type="submit" class="button-primary">
                Change Password
            </button>

            @if (!Model.Required)
            {
                <a class="button button-secondary" asp-page="/Assignments/Index">
                    Cancel
                </a>
            }
        </div>
    </form>
</div>